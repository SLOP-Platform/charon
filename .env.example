# Charon gateway — Docker environment. Copy this file to `.env` and fill it in:
#
#   cp .env.example .env
#
# docker compose reads `.env` automatically. `.env` is gitignored — never commit
# a real token.

# REQUIRED. The gateway binds 0.0.0.0 inside the container and holds your
# provider keys, so it refuses to start without a token. Generate one:
#
#   openssl rand -hex 16
#
# Clients send this value as their OpenAI API key (Authorization: Bearer <token>).
CHARON_GATEWAY_TOKEN=
